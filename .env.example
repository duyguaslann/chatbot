USE_PROVIDER=groq

GROQ_API_KEY=gsk-your-groq-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here

# PostgreSQL — yerel geliştirme için localhost, Docker için "postgres"
DB_HOST=localhost
DB_NAME=chatbot_db
DB_USER=postgres
DB_PASS=your-database-password-here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DAILY_MESSAGE_LIMIT=40

BASE_OPENAI_MODEL=gpt-4o-mini
FINE_TUNED_MODEL=gpt-4o-mini

SIMILARITY_THRESHOLD=0.28
MAX_USER_HISTORY_CONTEXT=2

SECRET_KEY=your-flask-secret-key-here

# ChromaDB — yerel için localhost, Docker için "chromadb"
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# Ollama — yerel için localhost, Docker için "ollama"
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5001
